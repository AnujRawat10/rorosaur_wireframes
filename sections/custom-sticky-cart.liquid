<!-- STICKY BAR -->
<div class="csc-bar" id="cscBar-{{ section.id }}">
  <div class="csc-bar__inner">
    <div class="csc-bar__price">
      {{ section.settings.price }} <span>{{ section.settings.label }}</span>
    </div>
    <div class="csc-bar__btn" id="cscOpenDrawer-{{ section.id }}">
      {{ section.settings.button_text | default: 'Add to Cart' }}
    </div>
  </div>
</div>

<!-- DRAWER -->
<div class="csc-overlay" id="cscOverlay-{{ section.id }}"></div>
<div class="csc-drawer" id="cscDrawer-{{ section.id }}">
  <div class="csc-drawer__content">

    <div class="csc-drawer__header">
      <h3>{{ section.settings.drawer_title }}</h3>
      <span class="csc-drawer__close" id="cscClose-{{ section.id }}">✕</span>
    </div>

    <!-- BUNDLES -->
    {% if section.blocks.size > 0 %}
      <div class="csc-drawer__section">
        <h4>{{ section.settings.bundles_heading | default: 'Recommended Bundles' }}</h4>
        <div class="csc-bundle-grid">
          {% for block in section.blocks %}
            {% if block.type == 'bundle' %}
              <div class="csc-bundle-card" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.name }}" loading="lazy">
                {% endif %}
                <p>{{ block.settings.name }}</p>
                <span>{{ block.settings.price }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <!-- VARIANTS -->
    <div class="csc-drawer__section">
      <h4>Select Pack</h4>
      {% for block in section.blocks %}
        {% if block.type == 'variant' %}
          <div class="csc-variant {% if forloop.first %}csc-variant--active{% endif %}" {{ block.shopify_attributes }}>
            {{ block.settings.label }} - {{ block.settings.price }}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- QTY + CTA -->
    <div class="csc-qty-cta">
      <div class="csc-qty">
        <button class="csc-qty__btn" data-action="decrease">−</button>
        <span class="csc-qty__val">1</span>
        <button class="csc-qty__btn" data-action="increase">+</button>
      </div>
      <button class="csc-cta-btn">{{ section.settings.cta_text | default: 'Add to Cart' }}</button>
    </div>

  </div>
</div>

<style>
  /* ===== STICKY BAR ===== */
  .csc-bar{
    position:fixed;
    bottom:0;left:0;
    width:100%;
    background:#fff;
    border-top:1px solid #E5E7EB;
    padding:10px 16px;
    z-index:999;
  }
  .csc-bar__inner{
    display:flex;
    justify-content:space-between;
    align-items:center;
    max-width:600px;
    margin:0 auto;
  }
  .csc-bar__price{
    font-weight:700;
    font-size:18px;
    color:#ed2d5e;
  }
  .csc-bar__price span{
    font-size:12px;
    color:#6B7280;
    font-weight:400;
  }
  .csc-bar__btn{
    background:#ed2d5e;
    color:#fff;
    padding:13px 22px;
    border-radius:10px;
    font-weight:700;
    font-size:14px;
    cursor:pointer;
  }

  /* ===== OVERLAY ===== */
  .csc-overlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.4);
    z-index:999;
    opacity:0;
    pointer-events:none;
    transition:opacity .3s;
  }
  .csc-overlay.active{
    opacity:1;
    pointer-events:all;
  }

  /* ===== DRAWER ===== */
  .csc-drawer{
    position:fixed;
    bottom:-100%;
    left:0;
    width:100%;
    background:#fff;
    border-radius:20px 20px 0 0;
    box-shadow:0 -10px 30px rgba(0,0,0,.2);
    transition:bottom .4s ease;
    z-index:1000;
    max-height:70vh;
    overflow-y:auto;
  }
  .csc-drawer.active{bottom:0}
  .csc-drawer__content{
    padding:20px 16px;
    max-width:600px;
    margin:0 auto;
  }
  .csc-drawer__header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:18px;
  }
  .csc-drawer__header h3{
    font-size:18px;
    color:#2B2D42;
    margin:0;
  }
  .csc-drawer__close{
    font-size:20px;
    cursor:pointer;
    color:#6B7280;
    padding:4px;
  }
  .csc-drawer__section{
    margin-bottom:18px;
  }
  .csc-drawer__section h4{
    font-size:14px;
    margin:0 0 10px;
    color:#2B2D42;
  }
  /* Bundles */
  .csc-bundle-grid{
    display:flex;
    gap:10px;
    overflow-x:auto;
  }
  .csc-bundle-grid::-webkit-scrollbar{display:none}
  .csc-bundle-card{
    min-width:120px;
    background:#fff;
    border:1px solid #E5E7EB;
    border-radius:10px;
    padding:10px;
    text-align:center;
    cursor:pointer;
  }
  .csc-bundle-card img{
    width:100%;
    height:80px;
    object-fit:cover;
    border-radius:8px;
    margin-bottom:6px;
  }
  .csc-bundle-card p{
    font-size:12px;
    color:#6B7280;
    margin:0 0 2px;
  }
  .csc-bundle-card span{
    font-size:12px;
    font-weight:600;
    color:#2B2D42;
  }
  .csc-bundle-card:hover{border-color:#ed2d5e}
  /* Variants */
  .csc-variant{
    border:2px solid #E5E7EB;
    padding:14px 16px;
    border-radius:10px;
    margin-bottom:8px;
    font-size:14px;
    font-weight:500;
    cursor:pointer;
    color:#2B2D42;
  }
  .csc-variant--active{border-color:#2B2D42}
  /* Qty + CTA */
  .csc-qty-cta{
    display:flex;
    align-items:stretch;
    margin-top:14px;
    border:1px solid #E5E7EB;
    border-radius:10px;
    overflow:hidden;
    background:#fff;
  }
  .csc-qty{
    display:flex;
    align-items:center;
    gap:14px;
    padding:0 14px;
    background:#F7F7F7;
  }
  .csc-qty__btn{
    all:unset;
    cursor:pointer;
    font-weight:600;
    font-size:16px;
  }
  .csc-qty__val{
    min-width:16px;
    text-align:center;
    font-weight:600;
  }
  .csc-cta-btn{
    flex:1;
    background:#2B2D42;
    color:#fff;
    border:none;
    font-weight:700;
    font-size:16px;
    padding:18px 0;
    letter-spacing:.5px;
    cursor:pointer;
    border-radius:0 10px 10px 0;
  }
  .csc-cta-btn:hover{opacity:.92}

  /* ===== DESKTOP ===== */
  @media(min-width:750px){
    .csc-bar{padding:14px 20px;box-shadow:0 -4px 20px rgba(0,0,0,.08)}
    .csc-bar__inner{max-width:500px}
    .csc-bar__price{font-size:20px}
    .csc-bar__btn{padding:16px 40px;font-size:16px;border-radius:12px;transition:.2s}
    .csc-bar__btn:hover{opacity:.9;transform:scale(1.02)}

    .csc-drawer{
      width:500px;
      left:50%;
      transform:translateX(-50%);
      border-radius:20px 20px 0 0;
      max-height:75vh;
    }
    .csc-drawer.active{bottom:0;transform:translateX(-50%)}
    .csc-drawer__content{padding:30px}
    .csc-bundle-card{min-width:160px;padding:14px}
    .csc-bundle-card img{height:100px}
  }
</style>

<script>
  (function(){
    const id = '{{ section.id }}';
    const openBtn = document.getElementById('cscOpenDrawer-'+id);
    const closeBtn = document.getElementById('cscClose-'+id);
    const drawer = document.getElementById('cscDrawer-'+id);
    const overlay = document.getElementById('cscOverlay-'+id);

    function open(){ drawer.classList.add('active'); overlay.classList.add('active'); }
    function close(){ drawer.classList.remove('active'); overlay.classList.remove('active'); }

    if(openBtn) openBtn.addEventListener('click', open);
    if(closeBtn) closeBtn.addEventListener('click', close);
    if(overlay) overlay.addEventListener('click', close);

    // Qty
    drawer.querySelectorAll('.csc-qty__btn').forEach(btn => {
      btn.addEventListener('click', function(){
        const val = this.parentElement.querySelector('.csc-qty__val');
        let n = parseInt(val.textContent);
        if(this.dataset.action === 'increase') n++;
        else if(n > 1) n--;
        val.textContent = n;
      });
    });

    // Variant selection
    drawer.querySelectorAll('.csc-variant').forEach(v => {
      v.addEventListener('click', function(){
        drawer.querySelectorAll('.csc-variant').forEach(x => x.classList.remove('csc-variant--active'));
        this.classList.add('csc-variant--active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Sticky Cart + Drawer",
  "class": "section-sticky-cart",
  "settings": [
    {
      "type": "text",
      "id": "price",
      "label": "Display Price",
      "default": "₹749"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Price Label",
      "default": "Starter Pack"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Sticky Bar Button Text",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "drawer_title",
      "label": "Drawer Title",
      "default": "Muskmelon Mango Baby Puree"
    },
    {
      "type": "text",
      "id": "bundles_heading",
      "label": "Bundles Section Heading",
      "default": "Recommended Bundles"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Drawer CTA Text",
      "default": "Add to Cart"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Starter Pack"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "₹749"
        }
      ]
    },
    {
      "type": "variant",
      "name": "Variant Option",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Starter Pack"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "₹749"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sticky Cart + Drawer",
      "blocks": [
        { "type": "bundle", "settings": { "name": "Starter Pack", "price": "₹749" } },
        { "type": "bundle", "settings": { "name": "Value Combo", "price": "₹1349" } },
        { "type": "variant", "settings": { "label": "Starter Pack", "price": "₹749" } },
        { "type": "variant", "settings": { "label": "Value Combo", "price": "₹1349" } }
      ]
    }
  ]
}
{% endschema %}
