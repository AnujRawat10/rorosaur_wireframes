<section class="img-banner {% if section.settings.full_width %}img-banner--full{% endif %} {% if section.settings.show_button %}img-banner--has-btn{% endif %}">
  {% if section.settings.image != blank %}
    <img
      src="{{ section.settings.image | image_url: width: 1600 }}"
      alt="{{ section.settings.alt_text | default: 'Banner' }}"
      loading="lazy"
      class="img-banner__img"
    >
  {% endif %}
  {% if section.settings.show_button and section.settings.button_text != blank %}
    <a href="{{ section.settings.button_link }}" class="img-banner__btn">
      {{ section.settings.button_text }}
    </a>
  {% endif %}
</section>

<style>
  .img-banner{
    position:relative;
    overflow:hidden;
    line-height:0;
  }
  .img-banner--full .img-banner__img{
    width:100%;
    height:auto;
    object-fit:cover;
  }
  .img-banner:not(.img-banner--full){
    padding:0 16px;
  }
  .img-banner:not(.img-banner--full) .img-banner__img{
    width:100%;
    border-radius:12px;
    object-fit:cover;
  }
  /* Button overlay */
  .img-banner__btn{
    position:absolute;
    bottom:20px;
    left:50%;
    transform:translateX(-50%);
    background:#ed2d5e;
    color:#fff;
    padding:12px 24px;
    border-radius:30px;
    font-weight:600;
    font-size:13px;
    text-decoration:none;
    box-shadow:0 6px 20px rgba(0,0,0,.2);
    transition:.3s;
    white-space:nowrap;
  }
  .img-banner__btn:hover{
    transform:translateX(-50%) scale(1.05);
  }

  @media(min-width:750px){
    .img-banner{max-height:70vh}
    .img-banner__btn{
      padding:14px 32px;
      font-size:15px;
    }
    .img-banner:not(.img-banner--full){
      padding:0 20px;
      max-width:1200px;
      margin:0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "Image Banner",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt Text",
      "default": "Banner image"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width (edge to edge)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show Button Overlay",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Lab Test Report"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Image Banner"
    }
  ]
}
{% endschema %}
