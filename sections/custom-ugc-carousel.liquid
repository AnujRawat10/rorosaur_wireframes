<section class="cugc" style="background:{{ section.settings.bg_color }}">
  <div class="cugc__container">
    <h2 class="cugc__heading" style="color:{{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>

    <div class="cugc__wrap">
      <div class="cugc__arrow cugc__arrow--left" onclick="this.nextElementSibling.scrollBy({left:-240,behavior:'smooth'})">
        <i class="fa fa-chevron-left"></i>
      </div>

      <div class="cugc__carousel">
        {% for block in section.blocks %}
          <div class="cugc__item" {{ block.shopify_attributes }}>
            {% if block.type == 'video' %}
              {% if block.settings.video_url != blank %}
                <video src="{{ block.settings.video_url }}" muted autoplay loop playsinline></video>
              {% endif %}
            {% elsif block.type == 'image' %}
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 500 }}" alt="UGC" loading="lazy">
              {% endif %}
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="cugc__arrow cugc__arrow--right" onclick="this.previousElementSibling.scrollBy({left:240,behavior:'smooth'})">
        <i class="fa fa-chevron-right"></i>
      </div>
    </div>
  </div>
</section>

<style>
  .cugc{
    padding:40px 16px;
  }
  .cugc__container{
    max-width:1200px;
    margin:0 auto;
  }
  .cugc__heading{
    font-family:'Playfair Display',serif;
    font-size:22px;
    margin:0 0 4px;
  }
  .cugc__wrap{
    position:relative;
    margin-top:16px;
  }
  .cugc__carousel{
    display:flex;
    gap:14px;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;
  }
  .cugc__carousel::-webkit-scrollbar{display:none}
  .cugc__item{
    flex:0 0 200px;
    height:340px;
    border-radius:16px;
    overflow:hidden;
    scroll-snap-align:start;
    background:#000;
  }
  .cugc__item img,
  .cugc__item video{
    width:100%;
    height:100%;
    object-fit:cover;
  }
  /* arrows hidden on mobile */
  .cugc__arrow{
    display:none;
  }

  @media(min-width:750px){
    .cugc{padding:70px 40px}
    .cugc__heading{font-size:30px;text-align:center;margin-bottom:10px}
    .cugc__carousel{
      justify-content:center;
      gap:24px;
    }
    .cugc__item{
      flex:0 0 300px;
      height:440px;
    }
    .cugc__arrow{
      display:flex;
      position:absolute;
      top:50%;
      transform:translateY(-50%);
      background:#fff;
      border-radius:50%;
      width:40px;height:40px;
      align-items:center;
      justify-content:center;
      cursor:pointer;
      box-shadow:0 4px 10px rgba(0,0,0,.15);
      z-index:2;
    }
    .cugc__arrow--left{left:-16px}
    .cugc__arrow--right{right:-16px}
  }
</style>

{% schema %}
{
  "name": "UGC Carousel",
  "class": "section-ugc",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Moms. Real Results."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ed2d5e"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Carousel",
      "blocks": [
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
