<section class="ctl-timeline">
  <div class="ctl-timeline__container">
    <h2 class="ctl-timeline__heading">{{ section.settings.heading }}</h2>

    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.heading }}"
        loading="lazy"
        class="ctl-timeline__img"
      >
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="ctl-timeline__body">{{ section.settings.body }}</p>
    {% endif %}
  </div>
</section>

<style>
  .ctl-timeline{
    background:#fff;
    padding:30px 16px;
    text-align:center;
  }
  .ctl-timeline__container{
    max-width:700px;
    margin:0 auto;
  }
  .ctl-timeline__heading{
    font-family:'Playfair Display',serif;
    font-size:22px;
    color:#ed2d5e;
    margin:0 0 16px;
  }
  .ctl-timeline__img{
    width:100%;
    max-width:600px;
    margin:0 auto 16px;
    display:block;
  }
  .ctl-timeline__body{
    font-size:14px;
    color:#6B7280;
    line-height:1.6;
  }
  @media(min-width:750px){
    .ctl-timeline{padding:70px 20px}
    .ctl-timeline__heading{font-size:30px;margin-bottom:20px}
    .ctl-timeline__body{font-size:15px}
  }
</style>

{% schema %}
{
  "name": "Timeline / Results",
  "class": "section-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What You'll Notice"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Timeline Image"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "Less bloating and smoother feeding experience."
    }
  ],
  "presets": [
    {
      "name": "Timeline / Results"
    }
  ]
}
{% endschema %}
