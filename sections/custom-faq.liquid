<section class="cfaq" style="background:{{ section.settings.bg_color }}">
  <div class="cfaq__container">
    <h2 class="cfaq__heading" style="color:{{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>

    {% for block in section.blocks %}
      <details class="cfaq__item" {{ block.shopify_attributes }}>
        <summary class="cfaq__q">{{ block.settings.question }}</summary>
        <div class="cfaq__a">{{ block.settings.answer }}</div>
      </details>
    {% endfor %}
  </div>
</section>

<style>
  .cfaq{
    padding:30px 16px;
  }
  .cfaq__container{
    max-width:750px;
    margin:0 auto;
  }
  .cfaq__heading{
    font-family:'Playfair Display',serif;
    font-size:22px;
    margin:0 0 16px;
  }
  .cfaq__item{
    border-bottom:1px solid #E5E7EB;
    padding:14px 0;
  }
  .cfaq__q{
    cursor:pointer;
    font-weight:500;
    font-size:14px;
    color:#2B2D42;
    list-style:none;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }
  .cfaq__q::-webkit-details-marker{display:none}
  .cfaq__q::after{
    content:'+';
    font-size:20px;
    font-weight:300;
    color:#6B7280;
    transition:transform .3s;
  }
  details[open] .cfaq__q::after{
    content:'−';
  }
  .cfaq__a{
    font-size:13px;
    color:#6B7280;
    line-height:1.6;
    padding:10px 0 4px;
  }

  @media(min-width:750px){
    .cfaq{padding:70px 20px}
    .cfaq__heading{font-size:30px;margin-bottom:24px}
    .cfaq__q{font-size:16px;padding:4px 0}
    .cfaq__a{font-size:14px}
  }
</style>

{% schema %}
{
  "name": "FAQ",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fff8ed"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ed2d5e"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Is it safe for daily use?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Yes, made with 100% natural ingredients."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "Is it safe for daily use?", "answer": "Yes, made with 100% natural ingredients." } },
        { "type": "faq", "settings": { "question": "What age is it suitable for?", "answer": "Suitable for babies above 6 months." } },
        { "type": "faq", "settings": { "question": "Does it contain preservatives?", "answer": "No preservatives, no added sugar. 100% clean ingredients." } }
      ]
    }
  ]
}
{% endschema %}
