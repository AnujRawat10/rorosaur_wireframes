{{ 'custom-announcement-bar.css' | asset_url | stylesheet_tag }}

<div class="announcement-bar color-{{ section.settings.color_scheme }}" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }}">
  <div class="announcement-bar__inner">
    {% for block in section.blocks %}
      <span class="announcement-bar__text">{{ block.settings.text }}</span>
      {% unless forloop.last %}<span class="announcement-bar__sep">|</span>{% endunless %}
    {% endfor %}
  </div>
</div>

<style>
  .announcement-bar{
    text-align:center;
    padding:10px 16px;
    font-size:12px;
    font-family:var(--font-body-family, sans-serif);
    font-weight:500;
    letter-spacing:.3px;
    line-height:1.4;
  }
  .announcement-bar__inner{
    display:flex;
    justify-content:center;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }
  .announcement-bar__sep{
    opacity:.5;
  }
  @media(min-width:750px){
    .announcement-bar{
      font-size:14px;
      padding:12px 20px;
      letter-spacing:.5px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Announcement Bar",
  "class": "section-announcement",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Announcement Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping + COD Available"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar",
      "blocks": [
        { "type": "text", "settings": { "text": "Free Shipping + COD Available" } },
        { "type": "text", "settings": { "text": "Limited Stock" } }
      ]
    }
  ]
}
{% endschema %}
