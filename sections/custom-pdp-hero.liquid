<div class="pdp-hero">
  <div class="pdp-hero__container">

    <!-- TITLE (mobile only, above gallery) -->
    <div class="pdp-hero__title-mobile">
      <h1 class="pdp-hero__name">{{ section.settings.product_title }}</h1>
      <div class="pdp-hero__rating">★★★★★ {{ section.settings.rating }} ({{ section.settings.review_count }})</div>
    </div>

    <!-- IMAGE GALLERY -->
    <div class="pdp-hero__gallery">
      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          <div class="pdp-hero__slide {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ section.settings.product_title }}" loading="lazy">
          </div>
        {% elsif block.type == 'video' %}
          <div class="pdp-hero__slide {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <video src="{{ block.settings.video_url }}" muted autoplay loop playsinline></video>
          </div>
        {% endif %}
      {% endfor %}

      <div class="pdp-hero__dots">
        {% assign media_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'image' or block.type == 'video' %}
            <div class="pdp-hero__dot {% if media_count == 0 %}active{% endif %}" data-slide="{{ media_count }}"></div>
            {% assign media_count = media_count | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- PRODUCT INFO -->
    <div class="pdp-hero__info">

      <!-- TITLE (desktop only) -->
      <div class="pdp-hero__title-desktop">
        <h1 class="pdp-hero__name">{{ section.settings.product_title }}</h1>
        <div class="pdp-hero__rating">★★★★★ {{ section.settings.rating }} ({{ section.settings.review_count }})</div>
        <p class="pdp-hero__price">
          {{ section.settings.sale_price }}
          {% if section.settings.compare_price != blank %}
            <span class="pdp-hero__compare">{{ section.settings.compare_price }}</span>
          {% endif %}
        </p>
      </div>

      <p class="pdp-hero__desc">{{ section.settings.description }}</p>

      <!-- KEY INGREDIENTS ACCORDION -->
      {% if section.settings.show_ingredients %}
        <div class="pdp-hero__ingredients">
          <div class="pdp-hero__acc-header" onclick="this.parentElement.classList.toggle('open')">
            <span>{{ section.settings.ingredients_title | default: 'Key Ingredients' }}</span>
            <i class="fa fa-chevron-down pdp-hero__acc-icon"></i>
          </div>
          <div class="pdp-hero__acc-content">
            <div class="pdp-hero__acc-wrap">
              {% for block in section.blocks %}
                {% if block.type == 'ingredient' %}
                  <div class="pdp-hero__ingredient">
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.name }}">
                    {% endif %}
                    <h4>{{ block.settings.name }}</h4>
                    <p>{{ block.settings.benefit }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}

      <!-- QTY + CTA (desktop) -->
      <div class="pdp-hero__cta">
        <div class="pdp-hero__qty">
          <button class="pdp-hero__qty-btn" data-action="decrease" aria-label="decrease">−</button>
          <span class="pdp-hero__qty-val">1</span>
          <button class="pdp-hero__qty-btn" data-action="increase" aria-label="increase">+</button>
        </div>
        <button class="pdp-hero__buy-btn">{{ section.settings.cta_text | default: 'BUY IT NOW' }}</button>
      </div>

      <p class="pdp-hero__trust">✔ Loved by 1000+ parents &nbsp; ✔ Safe for daily use &nbsp; ✔ No preservatives</p>
    </div>

  </div>
</div>

<style>
  .pdp-hero{
    padding:0 16px;
  }
  .pdp-hero__container{
    max-width:1200px;
    margin:0 auto;
  }
  /* TITLE MOBILE */
  .pdp-hero__title-desktop{display:none}
  .pdp-hero__name{
    font-family:'Playfair Display',serif;
    font-size:22px;
    margin:12px 0 2px;
    color:#ed2d5e;
  }
  .pdp-hero__rating{
    font-size:13px;
    color:#ed2d5e;
    margin-bottom:8px;
  }
  .pdp-hero__price{
    font-size:28px;
    font-weight:700;
    color:#ed2d5e;
    margin:8px 0 0;
  }
  .pdp-hero__compare{
    text-decoration:line-through;
    color:#999;
    font-size:18px;
    margin-left:8px;
  }
  /* GALLERY */
  .pdp-hero__gallery{
    position:relative;
    background:#fff;
    border-radius:12px;
    overflow:hidden;
    height:380px;
  }
  .pdp-hero__slide{
    display:none;
    width:100%;
    height:100%;
  }
  .pdp-hero__slide.active{display:block}
  .pdp-hero__slide img,
  .pdp-hero__slide video{
    width:100%;
    height:100%;
    object-fit:contain;
  }
  .pdp-hero__dots{
    position:absolute;
    bottom:10px;
    left:50%;
    transform:translateX(-50%);
    display:flex;
    gap:6px;
  }
  .pdp-hero__dot{
    width:8px;height:8px;
    border-radius:50%;
    background:#ddd;
    cursor:pointer;
  }
  .pdp-hero__dot.active{background:#ed2d5e}

  /* INFO */
  .pdp-hero__desc{
    font-size:14px;
    color:#6B7280;
    line-height:1.6;
    margin:10px 0;
  }

  /* INGREDIENTS ACCORDION */
  .pdp-hero__ingredients{
    border:2px solid #ed2d5e;
    border-radius:35px;
    padding:14px 16px;
    margin:12px 0;
  }
  .pdp-hero__acc-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-weight:600;
    cursor:pointer;
    color:#ed2d5e;
    font-size:14px;
  }
  .pdp-hero__acc-icon{
    transition:transform .3s;
    font-size:12px;
  }
  .pdp-hero__ingredients.open .pdp-hero__acc-icon{
    transform:rotate(180deg);
  }
  .pdp-hero__acc-content{
    max-height:0;
    overflow:hidden;
    transition:max-height .4s ease;
  }
  .pdp-hero__ingredients.open .pdp-hero__acc-content{
    max-height:300px;
  }
  .pdp-hero__acc-wrap{
    display:flex;
    justify-content:center;
    gap:30px;
    padding:16px 0 4px;
    text-align:center;
  }
  .pdp-hero__ingredient img{
    width:55px;height:55px;
    object-fit:contain;
    margin:0 auto;
  }
  .pdp-hero__ingredient h4{
    margin:6px 0 2px;
    font-size:13px;
    color:#000;
  }
  .pdp-hero__ingredient p{
    font-size:11px;
    color:#6B7280;
  }

  /* CTA — hidden on mobile (sticky bar used instead) */
  .pdp-hero__cta{display:none}
  .pdp-hero__trust{display:none}

  /* ===== DESKTOP ===== */
  @media(min-width:750px){
    .pdp-hero{padding:40px 20px}
    .pdp-hero__container{
      display:flex;
      gap:40px;
      align-items:flex-start;
    }
    .pdp-hero__title-mobile{display:none}
    .pdp-hero__title-desktop{display:block;margin-bottom:10px}
    .pdp-hero__name{font-size:32px;margin:0 0 4px}
    .pdp-hero__gallery{
      flex:0 0 50%;
      height:540px;
      border-radius:16px;
    }
    .pdp-hero__info{
      flex:1;
      padding-top:10px;
    }
    .pdp-hero__desc{font-size:15px}
    .pdp-hero__ingredients{max-width:100%;margin-top:16px}

    /* show CTA on desktop */
    .pdp-hero__cta{
      display:flex;
      align-items:stretch;
      margin-top:20px;
      max-width:420px;
      border:1px solid #E5E7EB;
      border-radius:10px;
      overflow:hidden;
      background:#fff;
    }
    .pdp-hero__qty{
      display:flex;
      align-items:center;
      gap:14px;
      padding:0 14px;
      background:#F7F7F7;
    }
    .pdp-hero__qty-btn{
      all:unset;
      cursor:pointer;
      font-weight:600;
      font-size:16px;
    }
    .pdp-hero__qty-val{
      min-width:16px;
      text-align:center;
      font-weight:600;
    }
    .pdp-hero__buy-btn{
      flex:1;
      background:#2B2D42;
      color:#fff;
      border:none;
      font-weight:700;
      font-size:18px;
      padding:20px 30px;
      letter-spacing:.8px;
      cursor:pointer;
      border-radius:0 10px 10px 0;
    }
    .pdp-hero__buy-btn:hover{opacity:.92}
    .pdp-hero__trust{
      display:block;
      font-size:12px;
      color:#6B7280;
      margin-top:10px;
    }
  }
</style>

<script>
  (function(){
    const section = document.querySelector('.pdp-hero__gallery');
    if(!section) return;
    const slides = section.querySelectorAll('.pdp-hero__slide');
    const dots = section.querySelectorAll('.pdp-hero__dot');
    dots.forEach(dot => {
      dot.addEventListener('click', function(){
        const idx = parseInt(this.dataset.slide);
        slides.forEach(s => s.classList.remove('active'));
        dots.forEach(d => d.classList.remove('active'));
        slides[idx].classList.add('active');
        this.classList.add('active');
      });
    });
    // Qty buttons
    document.querySelectorAll('.pdp-hero__qty-btn').forEach(btn => {
      btn.addEventListener('click', function(){
        const val = this.parentElement.querySelector('.pdp-hero__qty-val');
        let n = parseInt(val.textContent);
        if(this.dataset.action === 'increase') n++;
        else if(n > 1) n--;
        val.textContent = n;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "PDP Hero",
  "class": "section-pdp-hero",
  "settings": [
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title",
      "default": "Muskmelon Mango Baby Puree"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count",
      "default": "1434+ parents"
    },
    {
      "type": "text",
      "id": "sale_price",
      "label": "Sale Price",
      "default": "₹749"
    },
    {
      "type": "text",
      "id": "compare_price",
      "label": "Compare Price",
      "default": "₹999"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Short Description",
      "default": "Craft fully Created to taste wonderful and Balance the Sugars and the Vitamins. All products are made only with Traditional Natural Ingredients for your peace of mind."
    },
    {
      "type": "checkbox",
      "id": "show_ingredients",
      "label": "Show Key Ingredients Accordion",
      "default": true
    },
    {
      "type": "text",
      "id": "ingredients_title",
      "label": "Ingredients Accordion Title",
      "default": "Key Ingredients"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "BUY IT NOW"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "video",
      "name": "Product Video",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        }
      ]
    },
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Ingredient Icon"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Mango"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "Benefit",
          "default": "Rich in Vit C"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Hero",
      "blocks": [
        { "type": "image" },
        { "type": "ingredient", "settings": { "name": "Mango", "benefit": "Rich in Vit C" } },
        { "type": "ingredient", "settings": { "name": "Muskmelon", "benefit": "Rich in Vit C" } }
      ]
    }
  ]
}
{% endschema %}
